# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=synapse
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/synapse

# LangSmith
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=synapse

# LLM
OPENAI_API_KEY=your_openai_api_key_here

# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Auth
SECRET_KEY=change-me-generate-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/test
